SPRING_PROFILES_ACTIVE=prod
APP_JWT_SECRET=replace-with-long-random-secret
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# Database from Railway MySQL plugin
SPRING_DATASOURCE_URL=jdbc:mysql://mysql.railway.internal:3306/railway
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace-me

# Redis from Railway Redis plugin
SPRING_DATA_REDIS_HOST=redis.railway.internal
SPRING_DATA_REDIS_PORT=6379
REDIS_PASSWORD=
